    {
      "id": "65QSw5uJtpXPBkuhWbCvV",
      "type": "text",
      "x": 3020.8333333333335,
      "y": 1229.0740931828818,
      "width": 481.2075317382811,
      "height": 70,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dotted",
      "roughness": 1,
