      "isDeleted": false,
      "boundElements": [],
      "updated": 1769279961626,
      "link": null,
      "locked": false,
      "text": "1. R peak - Pan & Tompkins or the Hamilton Segmenter algorithm (tallest peak)\n\n2. feature extraction ie P, Q, S, T points - looks backward and forward in specific time windows",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. R peak - Pan & Tompkins or the Hamilton Segmenter algorithm (tallest peak)\n\n2. feature extraction ie P, Q, S, T points - looks backward and forward in specific time windows",
      "autoResize": true,
      "lineHeight": 1.25
    },
