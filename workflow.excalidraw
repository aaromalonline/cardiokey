      "seed": 1722099237,
      "version": 40,
      "versionNonce": 1106691307,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769280032002,
      "link": null,
      "locked": false,
      "text": " Q-Point: The lowest value in the 80 ms interval before the R-peak.\n S-Point: The lowest value in the 80 ms interval after the R-peak.\n P-Wave: The highest value in the 200 ms interval before the Q-point.\n T-Wave: The highest value in the 400 ms interval after the S-point.",
      "fontSize": 13.999999999999993,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": " Q-Point: The lowest value in the 80 ms interval before the R-peak.\n S-Point: The lowest value in the 80 ms interval after the R-peak.\n P-Wave: The highest value in the 200 ms interval before the Q-point.\n T-Wave: The highest value in the 400 ms interval after the S-point.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Ls7FrxVaEXBfbM6F5wugA",
