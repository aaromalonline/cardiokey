      "versionNonce": 240878458,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769706812944,
      "link": null,
      "locked": false,
      "text": "or use euclidian distance - Store a \"Master Template\" (array of floats) for the authorized user, Subtract the current wave array from the Master array, square the differences, and sum them, \n  If the sum is near zero (below a strict threshold), User Identified.",
      "fontSize": 12.380608957691493,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "or use euclidian distance - Store a \"Master Template\" (array of floats) for the authorized user, Subtract the current wave array from the Master array, square the differences, and sum them, \n  If the sum is near zero (below a strict threshold), User Identified.",
      "autoResize": true,
      "lineHeight": 1.25
    },
