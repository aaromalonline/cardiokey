      "updated": 1769706821460,
      "link": null,
      "locked": false,
      "text": "analyzes a set of beats (e.g., 10 beats), identifies each one, and selects the final identity based on a majority vote",
      "fontSize": 11.004985740170174,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "analyzes a set of beats (e.g., 10 beats), identifies each one, and selects the final identity based on a majority vote",
      "autoResize": true,
      "lineHeight": 1.25
    },
