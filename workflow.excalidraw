    {
      "id": "HY1_2S1g4TM8FbN91B7tG",
      "type": "text",
      "x": 2677.4197099761595,
      "y": 1731.1369232048903,
      "width": 711.9665560531029,
      "height": 57.51040534734081,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dotted",
      "roughness": 1,
      "opacity": 100,
