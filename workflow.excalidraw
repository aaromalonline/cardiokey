    {
      "id": "TRCGgKrACWt3S4EGu56qH",
      "type": "text",
      "x": 2287.776976265922,
      "y": 1982.0568732501022,
      "width": 1162.9438833654378,
      "height": 30.951522394228732,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
