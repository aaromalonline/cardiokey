      "seed": 1566761829,
      "version": 522,
      "versionNonce": 14477370,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769702060180,
      "link": null,
      "locked": false,
      "text": "Apply Principal Component Analysis (PCA). This mathematical technique\nreduces the complex wave down to a small set of variables (e.g., 30 \"principal components\") \nthat describe the most unique shape features of that specific heartbeat",
      "fontSize": 15.336108092624212,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Apply Principal Component Analysis (PCA). This mathematical technique\nreduces the complex wave down to a small set of variables (e.g., 30 \"principal components\") \nthat describe the most unique shape features of that specific heartbeat",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "gBO6bDdAMxjJ4M5URo4ZF",
      "type": "text",
      "x": 2257.48376851589,
      "y": 1928.31704293936,
      "width": 1133.3931776863553,
      "height": 21.426479053571242,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b18",
      "roundness": null,
      "seed": 1604018763,
      "version": 647,
      "versionNonce": 1437628986,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769702236882,
      "link": null,
      "locked": false,
      "text": "Common algorithms used include Linear Discriminant Analysis (LDA) or Support Vector Machines (SVM) with an RBF kernel as classifiers ",
      "fontSize": 17.141183242856997,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Common algorithms used include Linear Discriminant Analysis (LDA) or Support Vector Machines (SVM) with an RBF kernel as classifiers ",
      "autoResize": true,
      "lineHeight": 1.25
    },
